{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NormalizedMessage",
  "allOf": [
    {
      "type": "object",
      "required": [
        "from",
        "to",
        "subject"
      ],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "cc": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "bcc": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "subject": {
          "type": "string"
        },
        "html": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "replyTo": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          ]
        },
        "attachments": {
          "type": "array",
          "items": {
            "title": "Attachment",
            "anyOf": [
              {
                "type": "object",
                "required": [
                  "filename",
                  "content"
                ],
                "properties": {
                  "filename": {
                    "type": "string"
                  },
                  "contentType": {
                    "type": "string"
                  },
                  "contentId": {
                    "type": "string"
                  },
                  "disposition": {
                    "anyOf": [
                      {
                        "const": "attachment",
                        "type": "string"
                      },
                      {
                        "const": "inline",
                        "type": "string"
                      }
                    ]
                  },
                  "content": {
                    "type": "string"
                  },
                  "url": {
                    "not": {}
                  }
                }
              },
              {
                "type": "object",
                "required": [
                  "filename",
                  "url"
                ],
                "properties": {
                  "filename": {
                    "type": "string"
                  },
                  "contentType": {
                    "type": "string"
                  },
                  "contentId": {
                    "type": "string"
                  },
                  "disposition": {
                    "anyOf": [
                      {
                        "const": "attachment",
                        "type": "string"
                      },
                      {
                        "const": "inline",
                        "type": "string"
                      }
                    ]
                  },
                  "url": {
                    "type": "string"
                  },
                  "content": {
                    "not": {}
                  }
                }
              }
            ]
          }
        },
        "headers": {
          "type": "object",
          "patternProperties": {
            "^(.*)$": {
              "type": "string"
            }
          }
        },
        "tags": {
          "type": "object",
          "patternProperties": {
            "^(.*)$": {
              "type": "string"
            }
          }
        }
      }
    },
    {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "html"
          ],
          "properties": {
            "html": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "text"
          ],
          "properties": {
            "text": {
              "type": "string"
            }
          }
        }
      ]
    }
  ]
}
